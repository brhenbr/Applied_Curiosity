@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix ns: <http://www.exemplo.com/ontologia/mochilas_voadoras#> .

ns:OntologiaMochilasVoadoras a owl:Ontology ;
    rdfs:comment "Ontologia simulada e inferida para o modelo lógico de uma empresa B2B de produtos de aventura (mochilas voadoras), baseada nos domínios de negócio (Bounded Contexts do DDD), propriedades de dados completas e vocabulário de negócio inferido." ;
    owl:versionIRI <http://www.exemplo.com/ontologia/mochilas_voadoras/1.1> .

# Conceitos (Classes) baseados em Domínios de Negócio (Bounded Contexts)
ns:ClienteContext a owl:Class ;
    rdfs:label "Contexto do Cliente" ;
    rdfs:comment "Representa entidades e conceitos relacionados ao cliente no domínio B2B (concessionárias)." .

ns:ProdutoContext a owl:Class ;
    rdfs:label "Contexto do Produto" ;
    rdfs:comment "Representa entidades e conceitos relacionados aos produtos da empresa, incluindo sua categorização." .

ns:VendasContext a owl:Class ;
    rdfs:label "Contexto de Vendas" ;
    rdfs:comment "Representa entidades e conceitos relacionados aos processos de vendas, pedidos e itens de pedido." .

ns:ProducaoContext a owl:Class ;
    rdfs:label "Contexto de Produção" ;
    rdfs:comment "Representa entidades e conceitos relacionados à fabricação, matérias-primas e fornecedores." .

ns:CadeiaLogisticaContext a owl:Class ;
    rdfs:label "Contexto da Cadeia Logística" ;
    rdfs:comment "Representa entidades e conceitos relacionados ao estoque, armazéns, envios e recebimento de matérias-primas." .

ns:RecursosHumanosContext a owl:Class ;
    rdfs:label "Contexto de Recursos Humanos" ;
    rdfs:comment "Representa entidades e conceitos relacionados aos funcionários, cargos e departamentos da empresa." .

ns:FinancasContext a owl:Class ;
    rdfs:label "Contexto de Finanças" ;
    rdfs:comment "Representa entidades e conceitos relacionados a transações financeiras, contabilidade e centros de custo." .

ns:TecnologiaInformacaoContext a owl:Class ;
    rdfs:label "Contexto de Tecnologia da Informação" ;
    rdfs:comment "Representa entidades e conceitos relacionados a projetos e tarefas de TI." .

# Entidades (Classes) do Modelo Lógico e suas associações a Bounded Contexts
# Cliente
ns:Cliente rdfs:subClassOf ns:ClienteContext ;
    rdfs:label "Cliente" ;
    rdfs:label "Concessionária" ; # Vocabulário de Negócio: sinônimo
    rdfs:label "Revendedor" ;    # Vocabulário de Negócio: sinônimo
    rdfs:comment "Representa uma entidade cliente, geralmente uma empresa (B2B) que compra produtos para revenda." .
ns:EnderecoCliente rdfs:subClassOf ns:ClienteContext ;
    rdfs:label "Endereço do Cliente" ;
    rdfs:comment "Endereço físico associado a um cliente." .

# Produto
ns:Produto rdfs:subClassOf ns:ProdutoContext ;
    rdfs:label "Produto" ;
    rdfs:label "Mercadoria" ; # Vocabulário de Negócio: sinônimo
    rdfs:label "Item de Venda" ; # Vocabulário de Negócio: sinônimo
    rdfs:label "SKU" ; # Vocabulário de Negócio: sinônimo
    rdfs:comment "Representa um item físico ou serviço oferecido para venda pela empresa." .
ns:CategoriaProduto rdfs:subClassOf ns:ProdutoContext ;
    rdfs:label "Categoria de Produto" ;
    rdfs:comment "Classificação hierárquica para organizar produtos." .
# Hierarquias de Produto (Inferidas)
ns:Veiculo a owl:Class ;
    rdfs:subClassOf ns:Produto ;
    rdfs:label "Veículo" ;
    rdfs:comment "Subclasse de Produto representando veículos." .
ns:Quadriciclo a owl:Class ;
    rdfs:subClassOf ns:Veiculo ;
    rdfs:label "Quadriciclo" ;
    rdfs:comment "Tipo específico de veículo." .
ns:BikeMontanha a owl:Class ;
    rdfs:subClassOf ns:Veiculo ;
    rdfs:label "Bike para Montanha" ;
    rdfs:comment "Tipo específico de bicicleta para uso em montanha." .
ns:EquipamentoVoador a owl:Class ;
    rdfs:subClassOf ns:Produto ;
    rdfs:label "Equipamento Voador" ;
    rdfs:comment "Subclasse de Produto representando equipamentos capazes de voar." .
ns:MochilaVoadora a owl:Class ;
    rdfs:subClassOf ns:EquipamentoVoador ;
    rdfs:label "Mochila Voadora" ;
    rdfs:comment "Tipo específico de equipamento voador." .

# Vendas
ns:Pedido rdfs:subClassOf ns:VendasContext ;
    rdfs:label "Pedido" ;
    rdfs:label "Ordem de Venda" ; # Vocabulário de Negócio: sinônimo
    rdfs:comment "Representa a solicitação de compra de produtos por um cliente." .
ns:ItemPedido rdfs:subClassOf ns:VendasContext ;
    rdfs:label "Item de Pedido" ;
    rdfs:comment "Representa um produto específico dentro de um pedido, com sua quantidade e preço." .

# Produção
ns:Fornecedor rdfs:subClassOf ns:ProducaoContext ;
    rdfs:label "Fornecedor" ;
    rdfs:label "Provedor" ; # Vocabulário de Negócio: sinônimo
    rdfs:comment "Entidade que fornece matérias-primas ou serviços à empresa." .
ns:MateriaPrima rdfs:subClassOf ns:ProducaoContext ;
    rdfs:label "Matéria-Prima" ;
    rdfs:label "Insumo" ; # Vocabulário de Negócio: sinônimo
    rdfs:label "Componente" ; # Vocabulário de Negócio: sinônimo
    rdfs:comment "Material bruto ou componente utilizado na fabricação de produtos." .
# Hierarquias de Matéria-Prima (Inferidas)
ns:Peca a owl:Class ;
    rdfs:subClassOf ns:MateriaPrima ;
    rdfs:label "Peça" ;
    rdfs:comment "Subclasse de Matéria-Prima representando peças mecânicas ou eletrônicas." .
ns:EquipamentoFabricacao a owl:Class ;
    rdfs:subClassOf ns:MateriaPrima ;
    rdfs:label "Equipamento para Fabricação" ;
    rdfs:comment "Subclasse de Matéria-Prima representando equipamentos utilizados no processo produtivo." .

ns:ReceitaProduto rdfs:subClassOf ns:ProducaoContext ;
    rdfs:label "Receita de Produto" ;
    rdfs:comment "Documento que detalha os materiais e passos para fabricar um produto." .
ns:ItemReceita rdfs:subClassOf ns:ProducaoContext ;
    rdfs:label "Item de Receita" ;
    rdfs:comment "Um componente específico ou matéria-prima dentro de uma receita de produto." .
ns:ProducaoOrdem rdfs:subClassOf ns:ProducaoContext ;
    rdfs:label "Ordem de Produção" ;
    rdfs:label "Ordem de Fabricação" ; # Vocabulário de Negócio: sinônimo
    rdfs:comment "Instrução para fabricar uma certa quantidade de um produto." .

# Cadeia Logística
ns:Estoque rdfs:subClassOf ns:CadeiaLogisticaContext ;
    rdfs:label "Estoque" ;
    rdfs:label "Inventário" ; # Vocabulário de Negócio: sinônimo
    rdfs:comment "Representa a quantidade de produtos ou matérias-primas disponíveis em um local de armazenamento." .
ns:Armazem rdfs:subClassOf ns:CadeiaLogisticaContext ;
    rdfs:label "Armazém" ;
    rdfs:label "Centro de Distribuição" ; # Vocabulário de Negócio: sinônimo
    rdfs:comment "Local físico para armazenamento de produtos e matérias-primas." .
ns:RotaEntrega rdfs:subClassOf ns:CadeiaLogisticaContext ;
    rdfs:label "Rota de Entrega" ;
    rdfs:comment "Caminho predefinido ou dinâmico para o transporte de mercadorias." .
ns:Envio rdfs:subClassOf ns:CadeiaLogisticaContext ;
    rdfs:label "Envio" ;
    rdfs:label "Expedição" ; # Vocabulário de Negócio: sinônimo
    rdfs:label "Logística de Saída" ; # Vocabulário de Negócio: sinônimo
    rdfs:comment "Registro da movimentação de produtos para fora do armazém, em direção ao cliente." .
ns:RecebimentoMateriaPrima rdfs:subClassOf ns:CadeiaLogisticaContext ;
    rdfs:label "Recebimento de Matéria-Prima" ;
    rdfs:label "Logística de Entrada" ; # Vocabulário de Negócio: sinônimo
    rdfs:comment "Registro da entrada de matérias-primas ou componentes na empresa." .

# RH
ns:Funcionario rdfs:subClassOf ns:RecursosHumanosContext ;
    rdfs:label "Funcionário" ;
    rdfs:label "Colaborador" ; # Vocabulário de Negócio: sinônimo
    rdfs:comment "Pessoa empregada pela empresa." .
ns:Cargo rdfs:subClassOf ns:RecursosHumanosContext ;
    rdfs:label "Cargo" ;
    rdfs:comment "Posição ou função ocupada por um funcionário na empresa." .
ns:FuncionarioCargo rdfs:subClassOf ns:RecursosHumanosContext ;
    rdfs:label "Associação Funcionário-Cargo" ;
    rdfs:comment "Associação entre um funcionário e seu cargo." .
ns:Departamento rdfs:subClassOf ns:RecursosHumanosContext ;
    rdfs:label "Departamento" ;
    rdfs:label "Área de Negócio" ; # Vocabulário de Negócio: sinônimo
    rdfs:comment "Unidade organizacional da empresa." .
# Hierarquias de Departamento (Inferidas)
ns:DepartamentoVendas a owl:Class ; rdfs:subClassOf ns:Departamento ; rdfs:label "Departamento de Vendas" .
ns:DepartamentoMarketing a owl:Class ; rdfs:subClassOf ns:Departamento ; rdfs:label "Departamento de Marketing" .
ns:DepartamentoRH a owl:Class ; rdfs:subClassOf ns:Departamento ; rdfs:label "Departamento de Recursos Humanos" .
ns:DepartamentoTI a owl:Class ; rdfs:subClassOf ns:Departamento ; rdfs:label "Departamento de Tecnologia da Informação" .
ns:DepartamentoFinancas a owl:Class ; rdfs:subClassOf ns:Departamento ; rdfs:label "Departamento de Finanças" .
ns:DepartamentoProducao a owl:Class ; rdfs:subClassOf ns:Departamento ; rdfs:label "Departamento de Produção" .
ns:DepartamentoLogistica a owl:Class ; rdfs:subClassOf ns:Departamento ; rdfs:label "Departamento de Logística" .

# Finanças
ns:FaturaVenda rdfs:subClassOf ns:FinancasContext ;
    rdfs:label "Fatura de Venda" ;
    rdfs:label "Nota Fiscal de Venda" ; # Vocabulário de Negócio: sinônimo
    rdfs:comment "Documento contábil que registra uma transação de venda e o valor devido." .
ns:ContaContabil rdfs:subClassOf ns:FinancasContext ;
    rdfs:label "Conta Contábil" ;
    rdfs:label "Conta do Plano de Contas" ; # Vocabulário de Negócio: sinônimo
    rdfs:comment "Classificação contábil de transações financeiras." .
ns:LancamentoContabil rdfs:subClassOf ns:FinancasContext ;
    rdfs:label "Lançamento Contábil" ;
    rdfs:label "Registro Contábil" ; # Vocabulário de Negócio: sinônimo
    rdfs:comment "Registro de uma transação financeira em uma conta contábil." .
ns:CentroCusto rdfs:subClassOf ns:FinancasContext ;
    rdfs:label "Centro de Custo" ;
    rdfs:comment "Unidade organizacional para rastreamento de despesas." .
ns:LancamentoContabilCC rdfs:subClassOf ns:FinancasContext ;
    rdfs:label "Associação Lançamento-Centro de Custo" ;
    rdfs:comment "Associação entre um lançamento contábil e seu centro de custo relacionado." .
ns:PagamentoFornecedor rdfs:subClassOf ns:FinancasContext ;
    rdfs:label "Pagamento a Fornecedor" ;
    rdfs:comment "Registro de um pagamento feito a um fornecedor." .

# TI
ns:ProjetoTI rdfs:subClassOf ns:TecnologiaInformacaoContext ;
    rdfs:label "Projeto de TI" ;
    rdfs:label "Iniciativa de Tecnologia" ; # Vocabulário de Negócio: sinônimo
    rdfs:comment "Projeto de desenvolvimento ou manutenção na área de Tecnologia da Informação." .
ns:TarefaTI rdfs:subClassOf ns:TecnologiaInformacaoContext ;
    rdfs:label "Tarefa de TI" ;
    rdfs:label "Chamado de TI" ; # Vocabulário de Negócio: sinônimo
    rdfs:comment "Atividade específica dentro de um projeto de TI ou de suporte." .

# Propriedades de Objeto (Relações entre Classes) - inferidas de FKs e semântica de negócio
ns:possuiEndereco a owl:ObjectProperty ; rdfs:label "possui endereço" ;
    rdfs:domain ns:Cliente ; rdfs:range ns:EnderecoCliente .

ns:pertenceACategoria a owl:ObjectProperty ; rdfs:label "pertence à categoria" ;
    rdfs:domain ns:Produto ; rdfs:range ns:CategoriaProduto .

ns:realizaPedido a owl:ObjectProperty ; rdfs:label "realiza pedido" ;
    rdfs:domain ns:Cliente ; rdfs:range ns:Pedido .

ns:contemItem a owl:ObjectProperty ; rdfs:label "contém item" ;
    rdfs:domain ns:Pedido ; rdfs:range ns:ItemPedido .

ns:refereProduto a owl:ObjectProperty ; rdfs:label "refere-se ao produto" ;
    rdfs:domain ns:ItemPedido ; rdfs:range ns:Produto .

ns:temEstoque a owl:ObjectProperty ; rdfs:label "tem estoque" ;
    rdfs:domain ns:Produto ; rdfs:range ns:Estoque .

ns:localizadoEmArmazem a owl:ObjectProperty ; rdfs:label "localizado em armazém" ;
    rdfs:domain ns:Estoque ; rdfs:range ns:Armazem .

ns:usaFornecedor a owl:ObjectProperty ; rdfs:label "usa fornecedor" ;
    rdfs:domain ns:RecebimentoMateriaPrima ; rdfs:range ns:Fornecedor .

ns:recebeMateriaPrima a owl:ObjectProperty ; rdfs:label "recebe matéria-prima" ;
    rdfs:domain ns:RecebimentoMateriaPrima ; rdfs:range ns:MateriaPrima .

ns:produzProduto a owl:ObjectProperty ; rdfs:label "produz produto" ;
    rdfs:domain ns:ReceitaProduto ; rdfs:range ns:Produto .

ns:requerMateriaPrima a owl:ObjectProperty ; rdfs:label "requer matéria-prima" ;
    rdfs:domain ns:ItemReceita ; rdfs:range ns:MateriaPrima .

ns:fazParteDaReceita a owl:ObjectProperty ; rdfs:label "faz parte da receita" ;
    rdfs:domain ns:ItemReceita ; rdfs:range ns:ReceitaProduto .

ns:baseadoEmReceita a owl:ObjectProperty ; rdfs:label "baseado em receita" ;
    rdfs:domain ns:ProducaoOrdem ; rdfs:range ns:ReceitaProduto .

ns:associadoAProdutoProduzido a owl:ObjectProperty ; rdfs:label "associado ao produto produzido" ;
    rdfs:domain ns:ProducaoOrdem ; rdfs:range ns:Produto .

ns:atuaEmCargo a owl:ObjectProperty ; rdfs:label "atua em cargo" ;
    rdfs:domain ns:FuncionarioCargo ; rdfs:range ns:Cargo .

ns:associadoAFuncionario a owl:ObjectProperty ; rdfs:label "associado a funcionário" ;
    rdfs:domain ns:FuncionarioCargo ; rdfs:range ns:Funcionario .

ns:geradaParaPedido a owl:ObjectProperty ; rdfs:label "gerada para pedido" ;
    rdfs:domain ns:FaturaVenda ; rdfs:range ns:Pedido .

ns:associadoAContaContabil a owl:ObjectProperty ; rdfs:label "associado a conta contábil" ;
    rdfs:domain ns:LancamentoContabil ; rdfs:range ns:ContaContabil .

ns:associadoACentroCusto a owl:ObjectProperty ; rdfs:label "associado a centro de custo" ;
    rdfs:domain ns:LancamentoContabilCC ; rdfs:range ns:CentroCusto .
ns:relacionadoALancamento a owl:ObjectProperty ; rdfs:label "relacionado a lançamento" ;
    rdfs:domain ns:LancamentoContabilCC ; rdfs:range ns:LancamentoContabil .

ns:pagaFornecedor a owl:ObjectProperty ; rdfs:label "paga fornecedor" ;
    rdfs:domain ns:PagamentoFornecedor ; rdfs:range ns:Fornecedor .

ns:pertenceAProjeto a owl:ObjectProperty ; rdfs:label "pertence a projeto" ;
    rdfs:domain ns:TarefaTI ; rdfs:range ns:ProjetoTI .

ns:designadoParaFuncionario a owl:ObjectProperty ; rdfs:label "designado para funcionário" ;
    rdfs:domain ns:TarefaTI ; rdfs:range ns:Funcionario .

ns:enviadoParaPedido a owl:ObjectProperty ; rdfs:label "enviado para pedido" ;
    rdfs:domain ns:Envio ; rdfs:range ns:Pedido .

ns:utilizaRota a owl:ObjectProperty ; rdfs:label "utiliza rota" ;
    rdfs:domain ns:Envio ; rdfs:range ns:RotaEntrega .

ns:realizaProducaoDe a owl:ObjectProperty ; rdfs:label "realiza produção de" ;
    rdfs:domain ns:ProducaoOrdem ; rdfs:range ns:Produto .


# Axiomas e Restrições Básicas (Inferidas)
ns:Pedido rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty ns:contemItem ;
    owl:minQualifiedCardinality 1 ;
    owl:onClass ns:ItemPedido
] ;
rdfs:comment "Todo Pedido deve conter pelo menos um Item de Pedido." .

ns:ItemPedido rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty ns:refereProduto ;
    owl:qualifiedCardinality 1 ;
    owl:onClass ns:Produto
] ;
rdfs:comment "Cada Item de Pedido deve referir-se a exatamente um Produto." .

ns:ItemReceita rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty ns:requerMateriaPrima ;
    owl:qualifiedCardinality 1 ;
    owl:onClass ns:MateriaPrima
] ;
rdfs:comment "Cada Item de Receita deve requerer exatamente uma Matéria-Prima." .

ns:ProducaoOrdem rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty ns:associadoAProdutoProduzido ;
    owl:qualifiedCardinality 1 ;
    owl:onClass ns:Produto
] ;
rdfs:comment "Toda Ordem de Produção é associada a exatamente um Produto a ser produzido." .

ns:FaturaVenda rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty ns:geradaParaPedido ;
    owl:qualifiedCardinality 1 ;
    owl:onClass ns:Pedido
] ;
rdfs:comment "Toda Fatura de Venda é gerada para exatamente um Pedido." .

ns:RecebimentoMateriaPrima rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty ns:usaFornecedor ;
    owl:qualifiedCardinality 1 ;
    owl:onClass ns:Fornecedor
] ;
rdfs:comment "Todo Recebimento de Matéria-Prima usa exatamente um Fornecedor." .

# Propriedades de Dados (DatatypeProperties) - COMPLETAS
# Cliente
ns:idCliente a owl:DatatypeProperty ; rdfs:domain ns:Cliente ; rdfs:range xsd:integer ; rdfs:label "identificador do cliente" ; rdfs:comment "Identificador único do cliente." .
ns:nomeCliente a owl:DatatypeProperty ; rdfs:domain ns:Cliente ; rdfs:range xsd:string ; rdfs:label "nome do cliente" ; rdfs:comment "Nome completo do cliente." .
ns:emailCliente a owl:DatatypeProperty ; rdfs:domain ns:Cliente ; rdfs:range xsd:string ; rdfs:label "email do cliente" ; rdfs:comment "Endereço de e-mail do cliente (único)." .
ns:dataCadastro a owl:DatatypeProperty ; rdfs:domain ns:Cliente ; rdfs:range xsd:date ; rdfs:label "data de cadastro" ; rdfs:comment "Data em que o cliente foi cadastrado." .

# Endereco_Cliente
ns:idEndereco a owl:DatatypeProperty ; rdfs:domain ns:EnderecoCliente ; rdfs:range xsd:integer ; rdfs:label "identificador do endereço" ; rdfs:comment "Identificador único do endereço." .
ns:logradouro a owl:DatatypeProperty ; rdfs:domain ns:EnderecoCliente ; rdfs:range xsd:string ; rdfs:label "logradouro" ; rdfs:comment "Rua, avenida, etc." .
ns:numero a owl:DatatypeProperty ; rdfs:domain ns:EnderecoCliente ; rdfs:range xsd:string ; rdfs:label "número" ; rdfs:comment "Número do endereço." .
ns:complemento a owl:DatatypeProperty ; rdfs:domain ns:EnderecoCliente ; rdfs:range xsd:string ; rdfs:label "complemento" ; rdfs:comment "Complemento do endereço." .
ns:bairro a owl:DatatypeProperty ; rdfs:domain ns:EnderecoCliente ; rdfs:range xsd:string ; rdfs:label "bairro" ; rdfs:comment "Bairro do endereço." .
ns:cidade a owl:DatatypeProperty ; rdfs:domain ns:EnderecoCliente ; rdfs:range xsd:string ; rdfs:label "cidade" ; rdfs:comment "Cidade do endereço." .
ns:estado a owl:DatatypeProperty ; rdfs:domain ns:EnderecoCliente ; rdfs:range xsd:string ; rdfs:label "estado" ; rdfs:comment "Estado do endereço." .
ns:cep a owl:DatatypeProperty ; rdfs:domain ns:EnderecoCliente ; rdfs:range xsd:string ; rdfs:label "CEP" ; rdfs:comment "Código de Endereçamento Postal." .

# Produto
ns:idProduto a owl:DatatypeProperty ; rdfs:domain ns:Produto ; rdfs:range xsd:integer ; rdfs:label "identificador do produto" ; rdfs:comment "Identificador único do produto (e.g., quadriciclo, mochila voadora)." .
ns:nomeProduto a owl:DatatypeProperty ; rdfs:domain ns:Produto ; rdfs:range xsd:string ; rdfs:label "nome do produto" ; rdfs:comment "Nome comercial do produto." .
ns:descricaoProduto a owl:DatatypeProperty ; rdfs:domain ns:Produto ; rdfs:range xsd:string ; rdfs:label "descrição do produto" ; rdfs:comment "Descrição detalhada do produto." .
ns:precoUnitarioVenda a owl:DatatypeProperty ; rdfs:domain ns:Produto ; rdfs:range xsd:decimal ; rdfs:label "preço unitário de venda" ; rdfs:comment "Preço de venda unitário do produto." .

# Categoria_Produto
ns:idCategoriaProduto a owl:DatatypeProperty ; rdfs:domain ns:CategoriaProduto ; rdfs:range xsd:integer ; rdfs:label "identificador da categoria de produto" ; rdfs:comment "Identificador único da categoria de produto." .
ns:nomeCategoria a owl:DatatypeProperty ; rdfs:domain ns:CategoriaProduto ; rdfs:range xsd:string ; rdfs:label "nome da categoria" ; rdfs:comment "Nome da categoria (e.g., Veículos, Acessórios, Equipamentos Voadores)." .

# Pedido
ns:idPedido a owl:DatatypeProperty ; rdfs:domain ns:Pedido ; rdfs:range xsd:integer ; rdfs:label "identificador do pedido" ; rdfs:comment "Identificador único do pedido de venda." .
ns:dataPedido a owl:DatatypeProperty ; rdfs:domain ns:Pedido ; rdfs:range xsd:dateTime ; rdfs:label "data do pedido" ; rdfs:comment "Data e hora em que o pedido foi feito." .
ns:statusPedido a owl:DatatypeProperty ; rdfs:domain ns:Pedido ; rdfs:range xsd:string ; rdfs:label "status do pedido" ; rdfs:comment "Status atual do pedido (e.g., 'Pendente', 'Em Processamento', 'Enviado', 'Entregue')." .

# Item_Pedido
ns:idItemPedido a owl:DatatypeProperty ; rdfs:domain ns:ItemPedido ; rdfs:range xsd:integer ; rdfs:label "identificador do item do pedido" ; rdfs:comment "Identificador único do item dentro de um pedido." .
ns:quantidadeItemPedido a owl:DatatypeProperty ; rdfs:domain ns:ItemPedido ; rdfs:range xsd:integer ; rdfs:label "quantidade do item do pedido" ; rdfs:comment "Quantidade do produto no item do pedido." .
ns:precoVendaItemPedido a owl:DatatypeProperty ; rdfs:domain ns:ItemPedido ; rdfs:range xsd:decimal ; rdfs:label "preço de venda do item do pedido" ; rdfs:comment "Preço pelo qual o produto foi vendido no pedido." .

# Estoque
ns:idEstoque a owl:DatatypeProperty ; rdfs:domain ns:Estoque ; rdfs:range xsd:integer ; rdfs:label "identificador do estoque" ; rdfs:comment "Identificador único do registro de estoque." .
ns:quantidadeDisponivel a owl:DatatypeProperty ; rdfs:domain ns:Estoque ; rdfs:range xsd:integer ; rdfs:label "quantidade disponível" ; rdfs:comment "Quantidade de produtos disponível em estoque." .
ns:localArmazenamento a owl:DatatypeProperty ; rdfs:domain ns:Estoque ; rdfs:range xsd:string ; rdfs:label "local de armazenamento" ; rdfs:comment "Local físico onde o produto está armazenado." .

