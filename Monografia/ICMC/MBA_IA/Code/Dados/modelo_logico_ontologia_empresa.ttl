ns:statusTarefaTI a owl:DatatypeProperty ; rdfs:domain ns:TarefaTI ; rdfs:range xsd:string ; rdfs:label "status da tarefa de TI" ; rdfs:comment "Status da tarefa (e.g., 'Aberto', 'Em Progresso', 'Fechado')." .

# Propriedades de Metadados de Governança (Inferidas)
# Estas propriedades podem ser aplicadas a todas as classes ou a DatatypeProperties, conforme a granularidade
ns:temClassificacaoConfidencialidade a owl:DatatypeProperty ;
    rdfs:label "tem classificação de confidencialidade" ;
    rdfs:domain owl:Thing ; # Pode ser aplicado a qualquer coisa (classe, propriedade)
    rdfs:range xsd:string ;
    rdfs:comment "Indica o nível de confidencialidade do dado (Público, Interno, Confidencial, Restrito)." .

ns:temProprietarioDado a owl:DatatypeProperty ;
    rdfs:label "tem proprietário do dado" ;
    rdfs:domain owl:Thing ;
    rdfs:range xsd:string ;
    rdfs:comment "Indica o departamento ou área responsável pela governança do dado." .

ns:temRegrasQualidadeDados a owl:DatatypeProperty ;
    rdfs:label "tem regras de qualidade de dados" ;
    rdfs:domain owl:Thing ;
    rdfs:range xsd:string ;
    rdfs:comment "Descreve regras específicas para garantir a qualidade do dado." .

ns:temFrequenciaAtualizacao a owl:DatatypeProperty ;
    rdfs:label "tem frequência de atualização" ;
    rdfs:domain owl:Thing ;
    rdfs:range xsd:string ;
    rdfs:comment "Define a periodicidade de atualização do dado (Diária, Mensal, Tempo Real, etc.)." .

ns:temRetencaoDadosAnos a owl:DatatypeProperty ;
    rdfs:label "tem retenção de dados (anos)" ;
    rdfs:domain owl:Thing ;
    rdfs:range xsd:integer ;
    rdfs:comment "Período em anos pelo qual o dado deve ser retido." .

ns:temRegraNegocioAssociada a owl:DatatypeProperty ;
    rdfs:label "tem regra de negócio associada" ;
    rdfs:domain owl:Thing ;
    rdfs:range xsd:string ;
    rdfs:comment "Descreve uma regra de negócio importante associada ao conceito ou dado." .

ns:referenciaTermoGlossarioDMBOK a owl:DatatypeProperty ;
    rdfs:label "referencia termo do glossário DMBOK" ;
    rdfs:domain owl:Thing ;
    rdfs:range xsd:string ;
    rdfs:comment "Link ou referência a um termo no glossário de dados da empresa." .